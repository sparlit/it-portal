// Production Prisma Schema for PostgreSQL
// IT Management Portal - Al Rayes Laundry

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("user")
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// IT Asset model
model Asset {
  id            String   @id @default(cuid())
  type          String
  name          String
  model         String
  serialNumber  String   @unique
  location      String
  ipAddress     String?
  status        String   @default("active")
  assignedTo    String?
  purchaseDate  String?
  warrantyEnd   String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// IT Ticket model
model Ticket {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  title       String
  description String?  @db.Text
  priority    String   @default("medium")
  status      String   @default("open")
  category    String?
  requester   String
  assignedTo  String?
  resolution  String?  @db.Text
  slaDeadline String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Visitor model
model Visitor {
  id             String   @id @default(cuid())
  name           String
  company        String?
  email          String?
  phone          String?
  purpose        String?  @db.Text
  hostName       String?
  hostDepartment String?
  checkInTime    String?
  checkOutTime   String?
  status         String   @default("expected")
  visitorType    String   @default("visitor")
  idType         String?
  idNumber       String?
  photoUrl       String?
  badgeNumber    String?
  vehicleNumber  String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Meeting model
model Meeting {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  date         String
  time         String
  duration     Int      @default(60)
  organizer    String?
  participants String?  @db.Text
  meetingType  String   @default("video")
  platform     String   @default("jitsi")
  meetingLink  String?
  location     String?
  agenda       String?  @db.Text
  status       String   @default("scheduled")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// License model
model License {
  id           String   @id @default(cuid())
  software     String
  vendor       String?
  licenseKey   String?
  purchaseDate String?
  expiryDate   String?
  seats        Int      @default(1)
  usedSeats    Int      @default(0)
  cost         String?
  category     String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Vendor model
model Vendor {
  id            String   @id @default(cuid())
  name          String
  category      String   @default("other")
  contactPerson String?
  email         String?
  phone         String?
  address       String?  @db.Text
  website       String?
  contractStart String?
  contractEnd   String?
  contractValue String?
  slaDetails    String?  @db.Text
  rating        Int      @default(0)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Backup model
model Backup {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("full")
  schedule  String?
  lastRun   String?
  nextRun   String?
  status    String   @default("success")
  size      String?
  retention String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Daily Check model
model DailyCheck {
  id        String   @id @default(cuid())
  task      String
  category  String?
  completed Boolean  @default(false)
  timestamp String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Credential model
model Credential {
  id          String   @id @default(cuid())
  system      String
  username    String?
  password    String?
  url         String?
  notes       String?  @db.Text
  category    String?
  lastUpdated String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Quick Note model
model QuickNote {
  id        String   @id @default(cuid())
  title     String
  content   String?  @db.Text
  category  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Notebook Page model
model NotebookPage {
  id        String   @id @default(cuid())
  title     String
  content   String?  @db.Text
  folder    String?
  tags      String?  @db.Text
  pinned    Boolean  @default(false)
  favorite  Boolean  @default(false)
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Calendar Event model
model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  date        String
  type        String   @default("reminder")
  reminder    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Knowledge Article model
model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  content   String?  @db.Text
  category  String?
  tags      String?  @db.Text
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Activity Log model
model ActivityLog {
  id        String   @id @default(cuid())
  user      String
  action    String
  category  String?
  details   String?  @db.Text
  ip        String?
  timestamp DateTime @default(now())
}

// Announcement model
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String?  @db.Text
  type      String   @default("general")
  priority  String   @default("normal")
  author    String?
  expiresAt String?
  read      Boolean  @default(false)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Budget Item model
model BudgetItem {
  id          String   @id @default(cuid())
  category    String   @default("other")
  description String?  @db.Text
  amount      Float    @default(0)
  date        String?
  type        String   @default("expense")
  approvedBy  String?
  status      String   @default("pending")
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Programme Charter model
model ProgrammeCharter {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  objectives      String?  @db.Text
  scope           String?  @db.Text
  outOfScope      String?  @db.Text
  startDate       String?
  endDate         String?
  budget          String?
  sponsor         String?
  projectManager  String?
  stakeholders    String?  @db.Text
  deliverables    String?  @db.Text
  milestones      String?  @db.Text
  risks           String?  @db.Text
  successCriteria String?  @db.Text
  assumptions     String?  @db.Text
  constraints     String?  @db.Text
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// System Alert model
model SystemAlert {
  id        String   @id @default(cuid())
  type      String   @default("info")
  title     String
  message   String?  @db.Text
  read      Boolean  @default(false)
  timestamp DateTime @default(now())
}

// Settings model
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Server Monitor model
model ServerMonitor {
  id        String   @id @default(cuid())
  name      String
  ip        String
  status    String   @default("online")
  cpu       Int      @default(0)
  memory    Int      @default(0)
  disk      Int      @default(0)
  uptime    String?
  updatedAt DateTime @updatedAt
}