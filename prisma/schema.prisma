generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CORE_Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  address       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users             CORE_User[]
  notifications     CORE_Notification[]
  auditLogs         CORE_AuditLog[]
  systemAlerts      CORE_SystemAlert[]
  settings          CORE_Setting[]
  visitors          CORE_Visitor[]

  it_assets         IT_Asset[]
  it_tickets        IT_Ticket[]
  it_licenses       IT_License[]
  it_credentials    IT_Credential[]
  it_monitors       IT_ServerMonitor[]

  lnd_customers     LND_Customer[]
  lnd_orders        LND_Order[]
  lnd_services      LND_Service[]
  lnd_tickets       LND_Ticket[]

  st_items          STORES_Item[]
  st_requisitions   STORES_Requisition[]

  maint_tasks       MAINT_Task[]

  trans_vehicles    TRANS_Vehicle[]
  trans_trips       TRANS_Trip[]

  crm_leads         CRM_Lead[]

  prod_batches      PROD_Batch[]
  prod_metrics      PROD_MachineMetric[]
}

model CORE_User {
  id               String      @id @default(cuid())
  username         String      @unique
  password         String
  name             String
  email            String?
  role             String      @default("USER")
  status           String      @default("ACTIVE")
  isThemePermanent Boolean     @default(false)
  themeConfig      Json?
  portalPermissions Json?
  tenantId         String
  tenant           CORE_Tenant @relation(fields: [tenantId], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model CORE_Notification {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    CORE_Tenant @relation(fields: [tenantId], references: [id])
  userId    String
  title     String
  message   String      @db.Text
  type      String      @default("INFO")
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())
}

model CORE_AuditLog {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    CORE_Tenant @relation(fields: [tenantId], references: [id])
  userId    String
  action    String
  entity    String
  details   Json?
  timestamp DateTime    @default(now())
}

model CORE_SystemAlert {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    CORE_Tenant @relation(fields: [tenantId], references: [id])
  title     String
  message   String?     @db.Text
  createdAt DateTime    @default(now())
}

model CORE_Setting {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    CORE_Tenant @relation(fields: [tenantId], references: [id])
  key       String
  value     String?     @db.Text
  @@unique([tenantId, key])
}

model IT_Asset {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        CORE_Tenant @relation(fields: [tenantId], references: [id])
  name          String
  type          String
  model         String?
  serialNumber  String      @unique
  location      String?
  status        String      @default("ACTIVE")
  ipAddress     String?
  notes         String?     @db.Text
  purchaseDate  String?
  warrantyEnd   String?
  parentId      String?
  parent        IT_Asset?   @relation("AssetHierarchy", fields: [parentId], references: [id])
  children      IT_Asset[]  @relation("AssetHierarchy")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model IT_Ticket {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      CORE_Tenant @relation(fields: [tenantId], references: [id])
  ticketId    String      @unique
  title       String
  description String?     @db.Text
  priority    String      @default("MEDIUM")
  status      String      @default("OPEN")
  requester   String
  assignedTo  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model IT_License {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        CORE_Tenant @relation(fields: [tenantId], references: [id])
  software      String
  expiryDate    String?
  createdAt     DateTime @default(now())
}

model IT_Credential {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        CORE_Tenant @relation(fields: [tenantId], references: [id])
  system        String
  createdAt     DateTime @default(now())
}

model IT_ServerMonitor {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        CORE_Tenant @relation(fields: [tenantId], references: [id])
  name          String
  status        String   @default("ONLINE")
  updatedAt     DateTime @updatedAt
}

model LND_Customer {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    CORE_Tenant  @relation(fields: [tenantId], references: [id])
  name      String
  phone     String
  email     String?
  orders    LND_Order[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model LND_Order {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       CORE_Tenant    @relation(fields: [tenantId], references: [id])
  customerId   String
  customer     LND_Customer   @relation(fields: [customerId], references: [id])
  orderNumber  String         @unique
  status       String         @default("RECEIVED")
  totalAmount  Float          @default(0)
  notes        String?        @db.Text
  expectedDate DateTime?
  receivedAt   DateTime       @default(now())
  deliveredAt  DateTime?
  stages       LND_Stage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model LND_Stage {
  id        String    @id @default(cuid())
  orderId   String
  order     LND_Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name      String
  status    String    @default("PENDING")
  updatedAt DateTime  @updatedAt
}

model LND_Service {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    CORE_Tenant @relation(fields: [tenantId], references: [id])
  name      String
  category  String
  price     Float
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model LND_Ticket {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      CORE_Tenant @relation(fields: [tenantId], references: [id])
  subject     String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
}

model STORES_Item {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        CORE_Tenant @relation(fields: [tenantId], references: [id])
  sku           String      @unique
  name          String
  category      String
  unit          String      @default("PCS")
  currentStock  Float       @default(0)
  minStockLevel Float       @default(10)
  reorderPoint  Float?      @default(15)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model STORES_Requisition {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        CORE_Tenant @relation(fields: [tenantId], references: [id])
  requisitionNo String      @unique
  department    String
  requestedBy   String
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  approvals     STORES_ApprovalAction[]
}

model STORES_ApprovalAction {
  id            String   @id @default(cuid())
  requisitionId String
  requisition   STORES_Requisition @relation(fields: [requisitionId], references: [id])
  userId        String
  action        String
  createdAt     DateTime @default(now())
}

model MAINT_Task {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    CORE_Tenant @relation(fields: [tenantId], references: [id])
  title     String
  type      String      @default("CORRECTIVE")
  priority  String      @default("MEDIUM")
  status    String      @default("OPEN")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model TRANS_Vehicle {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      CORE_Tenant @relation(fields: [tenantId], references: [id])
  plateNumber String      @unique
  model       String
  make        String?
  status      String      @default("AVAILABLE")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model TRANS_Trip {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        CORE_Tenant @relation(fields: [tenantId], references: [id])
  startLocation String
  endLocation   String
  status        String   @default("SCHEDULED")
  createdAt     DateTime @default(now())
}

model CRM_Lead {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    CORE_Tenant @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  phone     String
  status    String      @default("NEW")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model PROD_Batch {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      CORE_Tenant @relation(fields: [tenantId], references: [id])
  batchNumber String      @unique
  productName String
  status      String      @default("PLANNED")
  quantity    Float
  unit        String      @default("UNITS")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model PROD_MachineMetric {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      CORE_Tenant @relation(fields: [tenantId], references: [id])
  equipmentId String
  oee         Float
  timestamp   DateTime @default(now())
}

model CORE_Visitor {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        CORE_Tenant @relation(fields: [tenantId], references: [id])
  name          String
  company       String?
  purpose       String?
  status        String   @default("EXPECTED")
  checkInTime   String?
  createdAt     DateTime @default(now())
}
