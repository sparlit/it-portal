// Production-Grade Multi-tenant Prisma Schema (PostgreSQL)
// TSysLab Industrial-Grade IT & Laundry Ecosystem - Advanced V2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE MODULE: Multi-tenancy & Auth
// ==========================================

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  address       String?  @db.Text
  phone         String?
  email         String?
  logo          String?
  plan          String   @default("enterprise")
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  users             User[]
  assets            Asset[]
  tickets           Ticket[]
  laundryCustomers  LaundryCustomer[]
  laundryOrders     LaundryOrder[]
  laundryServices   LaundryService[]
  laundrySuppliers  LaundrySupplier[]
  laundryEquipment  LaundryEquipment[]
  inventoryItems    InventoryItem[]
  visitors          Visitor[]
  meetings          Meeting[]
  licenses          License[]
  backups           Backup[]
  dailyChecks       DailyCheck[]
  credentials       Credential[]
  quickNotes        QuickNote[]
  notebookPages     NotebookPage[]
  calendarEvents    CalendarEvent[]
  knowledgeArticles KnowledgeArticle[]
  activityLogs      ActivityLog[]
  announcements     Announcement[]
  budgetItems       BudgetItem[]
  programmeCharters ProgrammeCharter[]
  systemAlerts      SystemAlert[]
  settings          Setting[]
  serverMonitors    ServerMonitor[]
  systemMetrics     SystemMetric[]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  email     String?
  role      String   @default("user") // admin, operator, technician, driver
  status    String   @default("active")

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==========================================
// UNIFIED TICKETING MODULE
// ==========================================

model Ticket {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  ticketId    String   // Human readable ID (e.g., TKT-1001)
  module      String   // "IT" or "LAUNDRY"
  title       String
  description String?  @db.Text
  priority    String   @default("medium") // low, medium, high, critical
  status      String   @default("open")   // open, in_progress, resolved, closed
  category    String?

  requesterId String?
  requester   String   // Name of requester
  assignedTo  String?  // Name or ID of technician

  resolution  String?  @db.Text

  // SLA & Escalation
  slaDeadline    DateTime?
  escalationLevel Int       @default(0)
  lastEscalatedAt DateTime?

  // Links
  assetId     String?
  orderId     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, ticketId])
  @@index([tenantId, module])
  @@index([status])
}

// ==========================================
// INVENTORY & ASSET MODULE
// ==========================================

model InventoryItem {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  sku           String?
  name          String
  description   String?  @db.Text
  category      String   // "IT", "CHEMICALS", "PACKAGING", "UNIFORMS"
  quantity      Float    @default(0)
  unit          String   @default("pcs")
  minThreshold  Float    @default(5)
  location      String?

  supplierId    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, sku])
  @@index([tenantId, category])
}

model Asset {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  type          String   // Laptop, Server, Router, etc.
  name          String
  model         String
  serialNumber  String
  location      String
  ipAddress     String?
  status        String   @default("active")
  assignedTo    String?
  purchaseDate  DateTime?
  warrantyEnd   DateTime?
  notes         String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
}

// ==========================================
// LAUNDRY MANAGEMENT MODULE (REFINED)
// ==========================================

model LaundryCustomer {
  id          String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  email       String?
  phone       String
  address     String?  @db.Text
  loyaltyTier String   @default("standard")
  totalOrders Int      @default(0)
  notes       String?  @db.Text

  orders      LaundryOrder[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, phone])
}

model LaundryService {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  category    String
  price       Float
  unit        String   @default("piece")
  estimatedTime Int    @default(24) // Hours

  orderItems  LaundryOrderItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model LaundryOrder {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  orderNumber   String
  customerId    String
  customer      LaundryCustomer @relation(fields: [customerId], references: [id])

  status        String   @default("received") // received, cleaning, ready, out_for_delivery, delivered, cancelled
  totalAmount   Float    @default(0)
  paymentStatus String   @default("pending")

  items         LaundryOrderItem[]
  logistics     LaundryLogistics?
  payments      LaundryPayment[]

  receivedAt    DateTime @default(now())
  expectedDate  DateTime?
  deliveredAt   DateTime?

  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, orderNumber])
  @@index([tenantId, customerId])
}

model LaundryOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       LaundryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  serviceId   String
  service     LaundryService @relation(fields: [serviceId], references: [id])

  quantity    Int      @default(1)
  unitPrice   Float
  subtotal    Float
  garmentType String?
  color       String?
  brand       String?
  specialInstructions String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LaundryLogistics {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         LaundryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  pickupScheduledAt  DateTime?
  pickupCompletedAt   DateTime?
  deliveryScheduledAt DateTime?
  deliveryCompletedAt  DateTime?

  driverName    String?
  vehicleId     String?
  address       String   @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LaundryPayment {
  id            String   @id @default(cuid())
  orderId       String
  order         LaundryOrder @relation(fields: [orderId], references: [id])

  amount        Float
  method        String
  transactionId String?
  status        String   @default("completed")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// METRICS & AUDIT MODULE
// ==========================================

model ActivityLog {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  
  userId        String?
  user          String   // Name or username for quick lookup
  action        String   // CREATE, UPDATE, DELETE, LOGIN
  module        String   // TICKETING, INVENTORY, CORE
  entityId      String?  // ID of the affected record
  details       String?  @db.Text // JSON string of changes
  ipAddress     String?
  
  timestamp     DateTime @default(now())

  @@index([tenantId, module])
  @@index([timestamp])
}

model SystemMetric {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  metricName    String   // API_LATENCY, CPU_USAGE, MEM_USAGE
  value         Float
  unit          String   // ms, %, MB
  endpoint      String?
  
  timestamp     DateTime @default(now())
  
  @@index([tenantId, metricName])
  @@index([timestamp])
}

// ==========================================
// SHARED UTILITY MODELS (MAINTAINED)
// ==========================================

model Visitor {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  company       String?
  purpose       String?  @db.Text
  checkInTime   String?
  checkOutTime  String?
  status        String   @default("expected")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Meeting {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  date          String
  time          String
  status        String   @default("scheduled")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model License {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  software      String
  expiryDate    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Backup {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  status        String   @default("success")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model DailyCheck {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  task          String
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Credential {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  system        String
  username      String?
  password      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model QuickNote {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  content       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model NotebookPage {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  content       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  date          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model KnowledgeArticle {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  content       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Announcement {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  content       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model BudgetItem {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  category      String
  amount        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model ProgrammeCharter {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model SystemAlert {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  message       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Setting {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  key           String
  value         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
  @@unique([tenantId, key])
}

model ServerMonitor {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  ip            String
  status        String   @default("online")
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model LaundryEquipment {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  name          String
  model         String?
  serialNumber  String?
  installationDate DateTime?
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  status        String   @default("operational")

  repairs       LaundryRepair[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

model LaundryRepair {
  id            String   @id @default(cuid())
  equipmentId   String
  equipment     LaundryEquipment @relation(fields: [equipmentId], references: [id])

  description   String   @db.Text
  cost          Float    @default(0)
  technician    String?
  repairDate    DateTime
  status        String   @default("completed")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LaundrySupplier {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  name          String
  contactPerson String?
  phone         String?
  email         String?
  category      String
  address       String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}
