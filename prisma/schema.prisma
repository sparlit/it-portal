generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  password      String
  name          String
  email         String    @unique
  role          String    @default("user")
  department    String?
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  tickets       Ticket[]          @relation("RequesterTickets")
  assignedTickets Ticket[]        @relation("AssignedTickets")
  activities    Activity[]
  notifications Notification[]
  sessions      Session[]
  assetsAssigned AssetAssignment[]
  maintenanceRecords MaintenanceRecord[]
  
  @@index([role])
  @@index([department])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([token])
  @@map("sessions")
}

model Activity {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  entityType  String
  entityId    Int?
  details     String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([entityType, entityId])
  @@map("activities")
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String   @db.Text
  type        String   @default("info")
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())
  
  @@index([userId, isRead])
  @@map("notifications")
}

model Asset {
  id              Int       @id @default(autoincrement())
  assetTag        String    @unique
  name            String
  category        String
  subCategory     String?
  brand           String?
  model           String?
  serialNumber    String?   @unique
  purchaseDate    DateTime?
  purchasePrice   Decimal?  @db.Decimal(12, 2)
  warrantyExpiry  DateTime?
  location        String?
  building        String?
  floor           String?
  room            String?
  status          String    @default("active")
  condition       String    @default("good")
  notes           String?   @db.Text
  image           String?
  assignedToId    Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  assignments     AssetAssignment[]
  maintenanceRecords MaintenanceRecord[]
  softwareLicenses AssetSoftwareLicense[]
  
  @@index([category])
  @@index([status])
  @@index([location])
  @@map("assets")
}

model AssetAssignment {
  id          Int      @id @default(autoincrement())
  assetId     Int
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt  DateTime @default(now())
  returnedAt  DateTime?
  notes       String?
  assignedBy  String?
  
  @@index([assetId])
  @@index([userId])
  @@map("asset_assignments")
}

model MaintenanceRecord {
  id              Int      @id @default(autoincrement())
  assetId         Int
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  performedById   Int?
  performedBy     User?    @relation(fields: [performedById], references: [id])
  type            String
  description     String   @db.Text
  cost            Decimal? @db.Decimal(12, 2)
  startDate       DateTime
  endDate         DateTime?
  status          String   @default("scheduled")
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  
  @@index([assetId])
  @@index([status])
  @@map("maintenance_records")
}

model Ticket {
  id              Int       @id @default(autoincrement())
  ticketNumber    String    @unique
  title           String
  description     String    @db.Text
  category        String
  subCategory     String?
  priority        String    @default("medium")
  status          String    @default("open")
  impact          String    @default("low")
  urgency         String    @default("low")
  
  requesterId     Int?
  requester       User?     @relation("RequesterTickets", fields: [requesterId], references: [id])
  requesterName   String
  requesterEmail  String?
  requesterPhone  String?
  requesterDept   String?
  
  assigneeId      Int?
  assignee        User?     @relation("AssignedTickets", fields: [assigneeId], references: [id])
  assignedAt      DateTime?
  
  resolution      String?   @db.Text
  resolvedAt      DateTime?
  resolvedById    Int?
  closedAt        DateTime?
  
  slaDueDate      DateTime?
  slaBreached     Boolean   @default(false)
  
  assetId         Int?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  comments        TicketComment[]
  attachments     TicketAttachment[]
  
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([assigneeId])
  @@index([requesterId])
  @@map("tickets")
}

model TicketComment {
  id          Int      @id @default(autoincrement())
  ticketId    Int
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    Int?
  authorName  String
  content     String   @db.Text
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  @@index([ticketId])
  @@map("ticket_comments")
}

model TicketAttachment {
  id          Int      @id @default(autoincrement())
  ticketId    Int
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  filename    String
  filepath    String
  filesize    Int
  mimetype    String
  uploadedBy  String?
  uploadedAt  DateTime @default(now())
  
  @@index([ticketId])
  @@map("ticket_attachments")
}

model Visitor {
  id              Int       @id @default(autoincrement())
  visitorPass     String    @unique
  name            String
  company         String?
  purpose         String
  category        String    @default("general")
  personToVisit   String
  department      String?
  phone           String?
  email           String?
  idType          String?
  idNumber        String?
  photo           String?
  vehicleNumber   String?
  
  checkIn         DateTime  @default(now())
  checkOut        DateTime?
  checkInBy       String?
  checkOutBy      String?
  status          String    @default("checked_in")
  
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  
  @@index([status])
  @@index([checkIn])
  @@map("visitors")
}

model Software {
  id              Int       @id @default(autoincrement())
  name            String
  vendor          String?
  version         String?
  category        String?
  description     String?   @db.Text
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  licenses        SoftwareLicense[]
  
  @@map("software")
}

model SoftwareLicense {
  id              Int       @id @default(autoincrement())
  softwareId      Int
  software        Software  @relation(fields: [softwareId], references: [id])
  licenseKey      String?
  licenseType     String
  seatsTotal      Int       @default(1)
  seatsUsed       Int       @default(0)
  purchaseDate    DateTime?
  purchasePrice   Decimal?  @db.Decimal(12, 2)
  vendor          String?
  invoiceNumber   String?
  startDate       DateTime?
  expiryDate      DateTime?
  renewalDate     DateTime?
  status          String    @default("active")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  assetLicenses   AssetSoftwareLicense[]
  
  @@index([expiryDate])
  @@index([status])
  @@map("software_licenses")
}

model AssetSoftwareLicense {
  id              Int       @id @default(autoincrement())
  assetId         Int
  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  licenseId       Int
  license         SoftwareLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  installedAt     DateTime  @default(now())
  installedBy     String?
  notes           String?
  
  @@unique([assetId, licenseId])
  @@map("asset_software_licenses")
}

model Announcement {
  id              Int       @id @default(autoincrement())
  title           String
  content         String    @db.Text
  category        String    @default("general")
  priority        String    @default("normal")
  authorName      String
  authorId        Int?
  isActive        Boolean   @default(true)
  isPinned        Boolean   @default(false)
  publishAt       DateTime?
  expireAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([isActive])
  @@index([isPinned])
  @@map("announcements")
}

model Department {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  code            String?   @unique
  description     String?
  managerName     String?
  location        String?
  phone           String?
  email           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("departments")
}

model Setting {
  id              Int       @id @default(autoincrement())
  key             String    @unique
  value           String    @db.Text
  description     String?
  category        String?
  updatedAt       DateTime  @updatedAt
  
  @@map("settings")
}

model Event {
  id              Int       @id @default(autoincrement())
  title           String
  description     String?   @db.Text
  category        String    @default("general")
  location        String?
  startDate       DateTime
  endDate         DateTime
  isAllDay        Boolean   @default(false)
  isRecurring     Boolean   @default(false)
  recurrenceRule  String?
  organizerId     Int?
  organizerName   String?
  status          String    @default("scheduled")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([startDate])
  @@index([category])
  @@map("events")
}

model Report {
  id              Int       @id @default(autoincrement())
  name            String
  type            String
  description     String?   @db.Text
  filters         String?   @db.Text
  createdBy       String?
  createdAt       DateTime  @default(now())
  
  @@map("reports")
}

model Vendor {
  id              Int       @id @default(autoincrement())
  name            String
  category        String?
  contactPerson   String?
  email           String?
  phone           String?
  address         String?   @db.Text
  website         String?
  notes           String?   @db.Text
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("vendors")
}