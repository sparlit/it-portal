// Production-Grade Multi-tenant Prisma Schema
// TSysLab Industrial-Grade IT & Laundry Ecosystem

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE MODULE: Multi-tenancy & Auth
// ==========================================

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  address       String?
  phone         String?
  email         String?
  logo          String?
  plan          String   @default("enterprise")
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  users             User[]
  assets            Asset[]
  itTickets         ITTicket[]
  laundryTickets    LaundryTicket[]
  laundryCustomers  LaundryCustomer[]
  laundryOrders     LaundryOrder[]
  laundryServices   LaundryService[]
  laundrySuppliers  LaundrySupplier[]
  laundryEquipment  LaundryEquipment[]
  visitors          Visitor[]
  meetings          Meeting[]
  licenses          License[]
  backups           Backup[]
  dailyChecks       DailyCheck[]
  credentials       Credential[]
  quickNotes        QuickNote[]
  notebookPages     NotebookPage[]
  calendarEvents    CalendarEvent[]
  knowledgeArticles KnowledgeArticle[]
  activityLogs      ActivityLog[]
  announcements     Announcement[]
  budgetItems       BudgetItem[]
  programmeCharters ProgrammeCharter[]
  systemAlerts      SystemAlert[]
  settings          Setting[]
  serverMonitors    ServerMonitor[]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  email     String?
  role      String   @default("user") // 'admin', 'it_manager', 'laundry_manager', 'staff', 'user'
  status    String   @default("active")

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==========================================
// IT MANAGEMENT MODULE
// ==========================================

model Asset {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  type          String   // 'computer', 'server', 'printer', 'network', 'other'
  name          String
  model         String
  serialNumber  String
  location      String
  ipAddress     String?
  status        String   @default("active")
  assignedTo    String?
  purchaseDate  String?
  warrantyEnd   String?
  notes         String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
}

model ITTicket {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  ticketId    String   // TKT-IT-001 format
  title       String
  description String?  @db.Text
  priority    String   @default("medium")
  status      String   @default("open")
  category    String?
  requester   String
  assignedTo  String?
  resolution  String?  @db.Text
  slaDeadline String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, ticketId])
  @@index([tenantId])
}

// ==========================================
// LAUNDRY MANAGEMENT MODULE
// ==========================================

model LaundryCustomer {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  email       String?
  phone       String
  address     String?  @db.Text
  loyaltyTier String   @default("standard")
  totalOrders Int      @default(0)
  notes       String?  @db.Text

  orders      LaundryOrder[]
  tickets     LaundryTicket[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, id])
  @@index([tenantId, phone])
}

model LaundryService {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String   // 'Dry Clean', 'Wash & Fold', 'Ironing', 'Stain Removal'
  category    String   // 'Garment', 'Bedding', 'Curtains'
  price       Float
  unit        String   @default("piece") // 'piece', 'kg'
  estimatedTime Int    @default(24) // in hours

  orderItems  LaundryOrderItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model LaundryOrder {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  orderNumber   String   // LND-001
  customerId    String
  customer      LaundryCustomer @relation(fields: [tenantId, customerId], references: [tenantId, id])

  status        String   @default("received") // 'received', 'sorting', 'processing', 'quality-check', 'ready', 'out-for-delivery', 'delivered', 'cancelled'
  totalAmount   Float    @default(0)
  paymentStatus String   @default("pending") // 'pending', 'partial', 'paid', 'refunded'

  items         LaundryOrderItem[]
  logistics     LaundryLogistics?
  payments      LaundryPayment[]

  receivedAt    DateTime @default(now())
  expectedDate  DateTime?
  deliveredAt   DateTime?

  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, id])
  @@unique([tenantId, orderNumber])
  @@index([tenantId, customerId])
}

model LaundryOrderItem {
  id          String   @id @default(cuid())
  tenantId    String
  orderId     String
  order       LaundryOrder @relation(fields: [tenantId, orderId], references: [tenantId, id], onDelete: Cascade)

  serviceId   String
  service     LaundryService @relation(fields: [serviceId], references: [id])

  quantity    Int      @default(1)
  unitPrice   Float
  subtotal    Float
  garmentType String?  // 'Shirt', 'Suit', 'Blanket'
  color       String?
  brand       String?
  specialInstructions String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, orderId])
}

model LaundryLogistics {
  id            String   @id @default(cuid())
  tenantId      String
  orderId       String
  order         LaundryOrder @relation(fields: [tenantId, orderId], references: [tenantId, id], onDelete: Cascade)

  pickupScheduledAt  DateTime?
  pickupCompletedAt   DateTime?
  deliveryScheduledAt DateTime?
  deliveryCompletedAt  DateTime?

  driverName    String?
  vehicleId     String?
  address       String   @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, orderId])
  @@index([tenantId, orderId])
}

model LaundryPayment {
  id            String   @id @default(cuid())
  tenantId      String
  orderId       String
  order         LaundryOrder @relation(fields: [tenantId, orderId], references: [tenantId, id], onDelete: Cascade)

  amount        Float
  method        String   // 'cash', 'card', 'online', 'wallet'
  transactionId String?
  status        String   @default("completed")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, orderId])
}

model LaundryTicket {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  ticketId    String   // CS-001
  customerId  String
  customer    LaundryCustomer @relation(fields: [tenantId, customerId], references: [tenantId, id])

  orderId     String?
  subject     String
  message     String   @db.Text
  priority    String   @default("medium")
  status      String   @default("open")
  type        String   @default("complaint") // 'complaint', 'feedback', 'inquiry'
  resolution  String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, ticketId])
  @@index([tenantId, customerId])
}

model LaundrySupplier {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  
  name          String
  contactPerson String?
  phone         String?
  email         String?
  category      String   // 'Chemicals', 'Machinery', 'Packaging', 'Uniforms'
  address       String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

model LaundryEquipment {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  name          String   // 'Washer Extractor 1', 'Dryer 2'
  model         String?
  serialNumber  String?
  installationDate DateTime?
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  status        String   @default("operational") // 'operational', 'down', 'maintenance'
  
  repairs       LaundryRepair[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

model LaundryRepair {
  id            String   @id @default(cuid())
  tenantId      String
  equipmentId   String
  equipment     LaundryEquipment @relation(fields: [equipmentId], references: [id])

  description   String   @db.Text
  cost          Float    @default(0)
  technician    String?
  repairDate    DateTime
  status        String   @default("completed") // 'pending', 'in-progress', 'completed'

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, equipmentId])
}

// ==========================================
// SHARED UTILITY MODELS (Migrated)
// ==========================================

model Visitor {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  company       String?
  purpose       String?  @db.Text
  checkInTime   String?
  checkOutTime  String?
  status        String   @default("expected")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Meeting {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  date          String
  time          String
  status        String   @default("scheduled")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model License {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  software      String
  expiryDate    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Backup {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  status        String   @default("success")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model DailyCheck {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  task          String
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Credential {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  system        String
  username      String?
  password      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model QuickNote {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  content       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model NotebookPage {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  content       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  date          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model KnowledgeArticle {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  content       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model ActivityLog {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  user          String
  action        String
  timestamp     DateTime @default(now())
  @@index([tenantId])
}

model Announcement {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  content       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model BudgetItem {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  category      String
  amount        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model ProgrammeCharter {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model SystemAlert {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  title         String
  message       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}

model Setting {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  key           String
  value         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
  @@unique([tenantId, key])
}

model ServerMonitor {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  ip            String
  status        String   @default("online")
  updatedAt     DateTime @updatedAt
  @@index([tenantId])
}